<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BlueWebView" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#2196F3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#BBDEFB</item>
        <item name="colorOnPrimaryContainer">#0D47A1</item>
        <item name="colorSecondary">#1976D2</item>
        <item name="colorSecondaryContainer">#BBDEFB</item>
        <item name="colorOnSecondaryContainer">#0D47A1</item>
        <item name="android:statusBarColor">#1976D2</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>
    <style name="Theme.BlueWebView.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1976D2</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BlueWebView</item>
    </style>
</resources>
